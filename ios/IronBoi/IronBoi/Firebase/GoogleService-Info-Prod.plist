<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PLACEHOLDER — REPLACE THIS FILE before archiving for TestFlight or
  the App Store. See ios/IronBoi/IronBoi/Firebase/README.md for setup
  instructions.

  This file ships intentionally broken so that Release archives against
  it fail at runtime ("Firebase configuration error") instead of
  silently using staging credentials. Better to crash than to leak
  prod users into the staging DB.
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>REPLACE_WITH_PROD_API_KEY</string>
	<key>BUNDLE_ID</key>
	<string>com.thecombinationrule.ironboi</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_WITH_PROD_GCM_SENDER_ID</string>
	<key>GOOGLE_APP_ID</key>
	<string>REPLACE_WITH_PROD_GOOGLE_APP_ID</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>PROJECT_ID</key>
	<string>ironboi-prod</string>
	<key>STORAGE_BUCKET</key>
	<string>ironboi-prod.firebasestorage.app</string>
</dict>
</plist>
