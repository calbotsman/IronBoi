  "PHILOSOPHY": [
    {
      "principle": "Progressive Overload",
      "icon": "📈",
      "summary": "Add weight, reps, or sets over time — the #1 driver of hypertrophy.",
      "detail": "Schoenfeld (2010): mechanical tension is the primary stimulus for muscle growth. Increase load by 2.5–5% when you hit the top of your rep range for 2 consecutive sessions."
    },
    {
      "principle": "Mechanical Tension > Metabolic Stress",
      "icon": "⚙️",
      "summary": "Lift heavy with full range of motion. The burn is secondary.",
      "detail": "Research shows stretched-position loading (e.g. deep squats, incline curls) produces superior hypertrophy vs. partial reps chasing the pump. Control the eccentric."
    },
    {
      "principle": "Frequency: 2× Per Muscle/Week",
      "icon": "🔁",
      "summary": "Each muscle group trained twice weekly outperforms once-weekly splits.",
      "detail": "Krieger (2010) meta-analysis: 2× weekly frequency produced 6% more hypertrophy than 1×. PPL×2 maximizes this. Protein synthesis peaks ~24–36h post-workout."
    },
    {
      "principle": "Volume: 10–20 Sets Per Muscle/Week",
      "icon": "📊",
      "summary": "More sets = more growth, up to your recovery limit.",
      "detail": "Schoenfeld & Grgic (2017): dose-response relationship between weekly sets and hypertrophy. At 38 with a cut goal, stay 12–16 sets/muscle/week. Avoid junk volume."
    },
    {
      "principle": "Rep Range: 6–30 All Build Muscle",
      "icon": "🎯",
      "summary": "Heavy, moderate, and light sets all work — if taken near failure.",
      "detail": "Schoenfeld et al. (2017): sets of 8–12 optimize the tension-fatigue tradeoff. Use heavy compounds (5–8 reps) for strength and lighter isolation (12–20 reps) for detail."
    },
    {
      "principle": "HIIT for Fat Loss, Not LSD Cardio",
      "icon": "🔥",
      "summary": "2× weekly HIIT on leg days. Preserves muscle. Burns more fat.",
      "detail": "Wilson et al. (2012): concurrent HIIT + resistance training preserves lean mass better than steady-state cardio during a cut. 20–30 min HIIT > 60 min jogging for body comp."
    },
    {
      "principle": "Rest 60–90s for Hypertrophy",
      "icon": "⏱",
      "summary": "Short rests keep metabolic stress high. Don't exceed 2 min on isolations.",
      "detail": "Schoenfeld et al. (2016): 60s rest produced similar hypertrophy to 3-min rest when volume was equated. Shorter rest increases GH response and caloric burn — ideal for a cut."
    },
    {
      "principle": "Sleep & Recovery Are Training",
      "icon": "😴",
      "summary": "7–9 hrs sleep is non-negotiable. You grow at rest, not in the gym.",
      "detail": "Dattilo et al. (2011): sleep deprivation elevates cortisol and reduces testosterone — devastating for a shred. At 38, testosterone recovery is slower. Protect your sleep."
    }
  ],
