# Non-secret environment config for the ironboi-staging project.
# Loaded automatically by firebase-tools at `firebase deploy --only functions`.
# Secrets (GEMINI_API_KEY) stay in Secret Manager via defineSecret — never here.

# Gemini function-calling tool loop (adapt_plan / accept / reject /
# ask_follow_up_question). ON for staging as of 2026-07-14. When this is
# false/absent the coach falls back to the deterministic keyword classifier
# and the LLM turn is a plain single-call reply.
#
# ROLLBACK: flip this line to false and run a FULL
#   firebase deploy --only functions --project ironboi-staging
# Never flip it per-service with `gcloud run services update` — the flag
# gates BOTH sides of the switchover across three services
# (onUserCoachMessageCreated, sendCoachMessage, sendCoachMessageHttp);
# flipping one creates a split-brain (no proposals at all, or duplicates),
# and the next firebase deploy silently clobbers gcloud-set env anyway.
IRONBOI_COACH_TOOL_LOOP_ENABLED=true
